# OMEMO Content Factory — example environment file.
#
# Copy this file to ".env" for local development:
#     cp .env.example .env        (bash)
#     Copy-Item .env.example .env (PowerShell)
#
# NEVER commit your real ".env" — it is git-ignored on purpose (PROJECT.md §6).
#
# Scope: ROADMAP Stage 1 (infrastructure only). Provider and integration secrets
# (LLM, Notion, Google Docs, Storage, Analytics) are introduced in their own
# ROADMAP stages and must NOT be added here ahead of those stages.
#
# Note: at Stage 1 these variables are read directly from the process
# environment. A ".env" auto-loader is intentionally not part of Stage 1.

# Application environment: development | testing | production
OMEMO_APP_ENV=development

# Logging verbosity: CRITICAL | ERROR | WARNING | INFO | DEBUG | NOTSET
OMEMO_LOG_LEVEL=INFO
